# Supabase (local dev defaults from `supabase start`)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Supabase Staging (eu-central-1) — put these into apps/web/.env.local, NOT committed
# VITE_SUPABASE_URL=https://gsrdpwoejnuigbxhfgyr.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_...  (new-format publishable key, safe for client)
#
# Never commit the service_role key (sb_secret_...) or personal access token (sbp_...).
# Service-role lives server-only (Edge Functions / Supabase Vault).
# Personal access token lives in your shell env as SUPABASE_ACCESS_TOKEN for CLI use.

# Logging
VITE_LOG_LEVEL=debug
